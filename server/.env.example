# Prime Intellect API — get keys from https://app.primeintellect.ai/dashboard/tokens
# Enable scopes: inference (required), sandbox (optional), tunnel (optional)
PRIME_API_KEY=
PRIME_TEAM_ID=

# Override default models (optional — see app/config.py for defaults)
# MODEL_FAST=google/gemini-2.5-flash
# MODEL_MEDIATOR=qwen/qwen3-30b-a3b-instruct-2507
# MODEL_QUALITY=meta-llama/llama-3.3-70b-instruct
# MODEL_VISION=google/gemini-2.5-flash
# MODEL_TRANSCRIPTION=google/gemini-2.5-flash
# MODEL_CODESIGN=MBZUAI-IFM/K2-Think-v2  # K2 Think V2 for HDL hardware reasoning

# Signal processing thresholds (optional — tune for your piezo hardware)
# PIEZO_SAMPLE_RATE=4000
# SPEECH_THRESHOLD=0.15
# PRE_SPEECH_THRESHOLD=0.05

# K2 Think V2 — MBZUAI/IFM 70B reasoning model (hackathon API)
K2_API_KEY=
K2_BASE_URL=https://api.k2think.ai/v1
K2_MODEL=MBZUAI-IFM/K2-Think-v2

# Google Gemini API — for Gemini Live realtime audio (bypasses Prime Intellect)
# Get keys from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Supabase Realtime — Snap Spectacles (hosted on snapcloud.dev)
# Get URL and anon key from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_CHANNEL=spectacles
